---
import { getCollection } from "astro:content";

import Pagination from "../../components/Pagination.astro";
import PostList from "../../components/PostList.astro";
import config from "../../config";
import Layout from "../../layouts/Layout.astro";
import { getDatabase, paginate, sortPostsByDate } from "@astrotion/astro/content";

export async function getStaticPaths() {
  const all = await getCollection("posts");
  const { totalPages } = paginate(all, 1);
  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: (i + 1).toString() },
  }));
}

const { page } = Astro.params;
const allPosts = sortPostsByDate(await getCollection("posts"));
const database = await getDatabase();
const { posts, totalPages, currentPage } = paginate(
  allPosts,
  parseInt(page, 10) || 1,
);
---

<Layout>
  <main class="py-12 lg:py-20">
    <article class="max-w-6xl mx-auto px-3">
      <header class="text-center mb-12">
        <h1 class:list={["mb-12 text-6xl title", config.index?.titleClasses]}>
          {database.title}
        </h1>
        <p class="mx-auto max-w-xl">
          Page {currentPage} of {totalPages}
        </p>
      </header>
      <PostList posts={posts.map((p) => p.data)} />
      <Pagination page={currentPage} pageCount={totalPages} />
    </article>
  </main>
</Layout>
<style
  define:vars={{
    titleFontFamily: config.index?.titleFontFamily || "inherit",
  }}
>
  .title {
    font-family: var(--titleFontFamily);
  }
</style>
